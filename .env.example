# chexian-query 配置文件示例
# 复制本文件为 .env(项目根),按需修改
#   cp .env.example .env       (Mac/Linux)
#   copy .env.example .env     (Windows)

############################################################
# 1. 数据根目录(所有人都需要)
############################################################
#
# 选项 A:本地数据(默认值,无需配置)
# DATA_BASE=./data
#
# 选项 B:Windows SMB 网络共享(同事用,推荐)
# 注意:写双正斜杠,反斜杠也接受但会自动归一
# DATA_BASE=//10.120.0.87/chexian-query/data
#
# 选项 C:中转机本地物理路径(数据负责人在中转机用)
# DATA_BASE=D:/chexian-share/data
#
# 选项 D:Mac 挂载的 SMB 共享
# DATA_BASE=/Volumes/chexian-query/data

############################################################
# 2. HTTPS 同步(仅数据负责人在 Win 中转机上需要)
############################################################
# 用 scripts/sync-https.mjs 从 VPS 拉 parquet 到本地。
# 同事不需要配置,留空即可。
#
# 三个变量来自 VPS 上 root 跑 scripts/setup-https-share.sh 的输出。
#
# HTTPS_BASE_URL=https://chexian.cretvalu.com/data/
# HTTPS_USER=chexian-data
# HTTPS_PASS=<在 VPS 上跑 setup-https-share.sh 后获得>
